import("//build/test.gni")
import("//foundation/multimedia/player_framework/config.gni")

module_output_path = "player_framework/player_framework/av_downloader"

ohos_unittest("av_downloader_manager_test") {
  module_out_path = module_output_path

  include_dirs = [
    "../",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/av_downloader_manager",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/downloaded_cache_loader",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/net_downloader",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/utils",
    "$MEDIA_PLAYER_ROOT_DIR/interfaces/inner_api/native",
    "$MEDIA_PLAYER_ROOT_DIR/services/include",
    "$MEDIA_PLAYER_ROOT_DIR/services/utils/include",
  ]

  cflags = [
    "-Wall",
    "-Werror",
    "-Dprivate=public",
    "-Dprotected=public",
  ]

  defines = [ "MEDIA_OHOS" ]

  sanitize = {
    cfi = true
    cfi_cross_dso = true
  }

  external_deps = [
    "c_utils:utils",
    "googletest:gmock",
    "hilog:libhilog",
    "media_foundation:media_foundation",
  ]

  deps = [
    "$MEDIA_PLAYER_ROOT_DIR/interfaces/inner_api/native:media_client",
    "$MEDIA_PLAYER_ROOT_DIR/services/dfx:media_service_dfx",
    "$MEDIA_PLAYER_ROOT_DIR/services/dfx:media_service_log_dfx",
    "$MEDIA_PLAYER_ROOT_DIR/services/services:media_service",
    "$MEDIA_PLAYER_ROOT_DIR/services/utils:media_service_utils",
  ]

  sources = [
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/av_downloader_manager/av_downloader_manager.cpp",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/av_downloader_manager/source_parse_agent.cpp",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/utils/path_utils.cpp",
    "av_downloader_manager_test.cpp",
    "source_parse_agent_test.cpp",
  ]

  resource_config_file =
      "$MEDIA_PLAYER_ROOT_DIR/test/unittest/resources/ohos_test.xml"
}

import("//build/test.gni")
import("//foundation/multimedia/player_framework/config.gni")

module_output_path = "player_framework/player_framework/player"

ohos_unittest("downloaded_sha256_hasher_test") {
  module_out_path = module_output_path

  include_dirs = [
    "../",
    "../common",
    "$MEDIA_PLAYER_ROOT_DIR/services/include",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/factory",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/engine_intf",
    "$MEDIA_PLAYER_ROOT_DIR/services/utils/include",
    "$MEDIA_PLAYER_ROOT_DIR/interfaces/inner_api/native",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/common",
    "$MEDIA_PLAYER_ROOT_DIR/services/engine/common/recorder_profiles",
    "$MEDIA_PLAYER_ROOT_DIR/services/dfx",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/downloaded_cache_loader",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/loader",
  ]

  cflags = [
    "-Wall",
    "-Werror",
    "-Dprivate=public",
    "-Dprotected=public",
  ]

  defines = [ "MEDIA_OHOS" ]

  sanitize = {
    cfi = true
    cfi_cross_dso = true
  }

  external_deps = [
    "c_utils:utils",
    "googletest:gmock",
    "hilog:libhilog",
    "openssl:libcrypto_shared",
    "zlib:shared_libz",
  ]

  deps = [
    "$MEDIA_PLAYER_ROOT_DIR/interfaces/inner_api/native:media_client",
    "$MEDIA_PLAYER_ROOT_DIR/services/dfx:media_service_dfx",
    "$MEDIA_PLAYER_ROOT_DIR/services/dfx:media_service_log_dfx",
    "$MEDIA_PLAYER_ROOT_DIR/services/services:media_service",
    "$MEDIA_PLAYER_ROOT_DIR/services/utils:media_service_utils",
  ]

  sources = [
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/downloaded_cache_loader/cache_manager_new.cpp",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/downloaded_cache_loader/cache_mapping_serializer.cpp",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/downloaded_cache_loader/cache_reader.cpp",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/downloaded_cache_loader/downloaded_cache_loader.cpp",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/downloaded_cache_loader/file_cache_manager.cpp",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/downloaded_cache_loader/path_validator.cpp",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/downloaded_cache_loader/play_strategy_serializer.cpp",
    "$MEDIA_PLAYER_ROOT_DIR/services/services/media_source/downloaded_cache_loader/sha256_hasher.cpp",
    "sha256_hasher_test.cpp",
  ]
}